<?xml version="1.0"?>
<!--
/**
 * Copies the customer's pickup selection from the quote onto the order
 * during checkout conversion (Magento\Quote\Model\Quote\ToOrder uses the
 * 'sales_convert_quote' fieldset with the 'to_order' aspect).
 *
 * Without this, quote.etechflow_isp_pickup_store_id / _pickup_at are never
 * promoted to the sales_order columns, so the admin pickup card, the
 * pickup-aware confirmation email, the staff/ready emails and the order
 * grid all see the order as a non-pickup order.
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:DataObject/etc/fieldset.xsd">
    <scope id="global">
        <fieldset id="sales_convert_quote">
            <field name="etechflow_isp_pickup_store_id">
                <aspect name="to_order"/>
            </field>
            <field name="etechflow_isp_pickup_at">
                <aspect name="to_order"/>
            </field>
        </fieldset>
    </scope>
</config>
